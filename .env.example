# Copy to .env and adjust. All values are optional (sane defaults shown).

# Bearer secret the shim requires on POST /search. Leave EMPTY for a keyless
# local deployment (the service then ignores Authorization). This is the value
# you store as the BYOK credential secret in LoreWeave provider-registry.
WEB_SEARCH_SECRET=

# Published host port for the shim (LoreWeave endpoint_base_url => http://host:PORT).
# Container-internal port stays 8090; this only changes the host-published port.
PORT=15487

# SearXNG's own secret_key (overrides searxng/settings.yml at runtime).
SEARXNG_SECRET=please-change-this-searxng-secret

# Full-page content extraction on search_depth="advanced".
ENABLE_EXTRACT=true
EXTRACT_TOP_N=3

# --- Fetch capability (Scrapling sidecar) ---
# Enable the /fetch + /fetch/bulk API and fetch_page/fetch_pages MCP tools.
ENABLE_FETCH=true
# MCP URL of the Scrapling sidecar. On the compose network this is the service
# name. Leave EMPTY to disable Scrapling — the shim then serves mode=http/auto
# via an in-process httpx+trafilatura fallback (no browser/stealth).
SCRAPLING_MCP_URL=http://scrapling:8000/mcp
# Default fetch behavior.
FETCH_DEFAULT_MODE=auto
FETCH_MAX_CHARS=8000
FETCH_BULK_MAX_URLS=10
